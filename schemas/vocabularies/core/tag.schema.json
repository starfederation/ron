{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ron.dev/schema/vocab/core/v1/tag",
  "title": "OpaqueTag",
  "description": "Implementation-defined tagged value for opaque data. Prefer a namespaced custom vocabulary when the payload has documented semantics.",
  "type": "object",
  "required": [
    "#tag"
  ],
  "additionalProperties": false,
  "properties": {
    "#tag": {
      "$ref": "#/$defs/payload"
    }
  },
  "$defs": {
    "payload": {
      "type": "array",
      "prefixItems": [
        {
          "title": "Tag",
          "description": "Implementation-defined opaque tag identifier.",
          "type": "integer",
          "minimum": 0,
          "maximum": 255
        },
        {
          "title": "Payload",
          "description": "Implementation-defined opaque payload value."
        }
      ],
      "items": false,
      "minItems": 2,
      "maxItems": 2
    }
  }
}
