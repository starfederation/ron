{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ron.dev/schema/vocab/spatial/v1/ray",
  "title": "Ray",
  "description": "Ray represented by origin and direction for picking, intersection tests, and spatial queries.",
  "type": "object",
  "required": [
    "#ray"
  ],
  "additionalProperties": false,
  "properties": {
    "#ray": {
      "$ref": "#/$defs/payload"
    }
  },
  "$defs": {
    "payload": {
      "type": "array",
      "prefixItems": [
        {
          "title": "Origin",
          "description": "Origin vector.",
          "$ref": "#/$defs/vec3"
        },
        {
          "title": "Direction",
          "description": "Direction vector.",
          "$ref": "#/$defs/vec3"
        }
      ],
      "items": false,
      "minItems": 2,
      "maxItems": 2
    },
    "vec3": {
      "type": "array",
      "prefixItems": [
        {
          "title": "X",
          "description": "X component.",
          "type": "number"
        },
        {
          "title": "Y",
          "description": "Y component.",
          "type": "number"
        },
        {
          "title": "Z",
          "description": "Z component.",
          "type": "number"
        }
      ],
      "items": false,
      "minItems": 3,
      "maxItems": 3
    }
  }
}
