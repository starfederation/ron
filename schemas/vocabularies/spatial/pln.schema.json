{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ron.dev/schema/vocab/spatial/v1/pln",
  "title": "Plane",
  "description": "Plane represented by normal vector and constant for clipping, half-space tests, and intersections.",
  "type": "object",
  "required": [
    "#pln"
  ],
  "additionalProperties": false,
  "properties": {
    "#pln": {
      "$ref": "#/$defs/payload"
    }
  },
  "$defs": {
    "payload": {
      "$ref": "#/$defs/plane"
    },
    "vec3": {
      "type": "array",
      "prefixItems": [
        {
          "title": "X",
          "description": "X component.",
          "type": "number"
        },
        {
          "title": "Y",
          "description": "Y component.",
          "type": "number"
        },
        {
          "title": "Z",
          "description": "Z component.",
          "type": "number"
        }
      ],
      "items": false,
      "minItems": 3,
      "maxItems": 3
    },
    "plane": {
      "type": "array",
      "prefixItems": [
        {
          "title": "Normal",
          "description": "Plane normal vector.",
          "$ref": "#/$defs/vec3"
        },
        {
          "title": "Constant",
          "description": "Plane constant.",
          "type": "number"
        }
      ],
      "items": false,
      "minItems": 2,
      "maxItems": 2
    }
  }
}
