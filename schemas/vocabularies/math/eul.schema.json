{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ron.dev/schema/vocab/math/v1/eul",
  "title": "Euler",
  "description": "Euler rotation as three angles plus rotation order. Useful when preserving editable axis-angle controls or source authoring data.",
  "type": "object",
  "required": [
    "#eul"
  ],
  "additionalProperties": false,
  "properties": {
    "#eul": {
      "$ref": "#/$defs/payload"
    }
  },
  "$defs": {
    "payload": {
      "type": "array",
      "prefixItems": [
        {
          "title": "X",
          "description": "X component.",
          "type": "number",
          "default": 0
        },
        {
          "title": "Y",
          "description": "Y component.",
          "type": "number",
          "default": 0
        },
        {
          "title": "Z",
          "description": "Z component.",
          "type": "number",
          "default": 0
        },
        {
          "title": "Order",
          "description": "Euler rotation order.",
          "enum": [
            "XYZ",
            "YXZ",
            "ZXY",
            "ZYX",
            "YZX",
            "XZY"
          ],
          "default": "XYZ"
        }
      ],
      "items": false,
      "minItems": 4,
      "maxItems": 4,
      "default": [
        0,
        0,
        0,
        "XYZ"
      ]
    }
  }
}
