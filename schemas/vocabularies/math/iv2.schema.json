{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ron.dev/schema/vocab/math/v1/iv2",
  "title": "IntVector2",
  "description": "Two-component integer vector for pixels, tiles, grid coordinates, and discrete 2D extents.",
  "type": "object",
  "required": [
    "#iv2"
  ],
  "additionalProperties": false,
  "properties": {
    "#iv2": {
      "$ref": "#/$defs/payload"
    }
  },
  "$defs": {
    "payload": {
      "type": "array",
      "prefixItems": [
        {
          "title": "X",
          "description": "X component.",
          "type": "integer",
          "default": 0
        },
        {
          "title": "Y",
          "description": "Y component.",
          "type": "integer",
          "default": 0
        }
      ],
      "items": false,
      "minItems": 2,
      "maxItems": 2,
      "default": [
        0,
        0
      ]
    }
  }
}
