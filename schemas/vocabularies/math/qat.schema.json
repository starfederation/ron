{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ron.dev/schema/vocab/math/v1/qat",
  "title": "Quaternion",
  "description": "Quaternion rotation in x, y, z, w order for compact 3D orientation and interpolation.",
  "type": "object",
  "required": [
    "#qat"
  ],
  "additionalProperties": false,
  "properties": {
    "#qat": {
      "$ref": "#/$defs/payload"
    }
  },
  "$defs": {
    "payload": {
      "type": "array",
      "prefixItems": [
        {
          "title": "X",
          "description": "X component.",
          "type": "number",
          "default": 0
        },
        {
          "title": "Y",
          "description": "Y component.",
          "type": "number",
          "default": 0
        },
        {
          "title": "Z",
          "description": "Z component.",
          "type": "number",
          "default": 0
        },
        {
          "title": "W",
          "description": "W component.",
          "type": "number",
          "default": 1
        }
      ],
      "items": false,
      "minItems": 4,
      "maxItems": 4,
      "default": [
        0,
        0,
        0,
        1
      ]
    }
  }
}
