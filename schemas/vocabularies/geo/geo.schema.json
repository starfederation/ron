{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ron.dev/schema/vocab/geo/v1/geo",
  "title": "GeoJSON",
  "description": "GeoJSON geometry, feature, or feature collection for geographic shapes, positions, and feature metadata.",
  "type": "object",
  "required": [
    "#geo"
  ],
  "additionalProperties": false,
  "properties": {
    "#geo": {
      "$ref": "#/$defs/payload"
    }
  },
  "$defs": {
    "payload": {
      "oneOf": [
        {
          "$ref": "#/$defs/point"
        },
        {
          "$ref": "#/$defs/multiPoint"
        },
        {
          "$ref": "#/$defs/lineString"
        },
        {
          "$ref": "#/$defs/multiLineString"
        },
        {
          "$ref": "#/$defs/polygon"
        },
        {
          "$ref": "#/$defs/multiPolygon"
        },
        {
          "$ref": "#/$defs/geometryCollection"
        },
        {
          "$ref": "#/$defs/feature"
        },
        {
          "$ref": "#/$defs/featureCollection"
        }
      ]
    },
    "position": {
      "type": "array",
      "items": {
        "type": "number"
      },
      "minItems": 2,
      "maxItems": 3
    },
    "lineStringCoordinates": {
      "type": "array",
      "items": {
        "type": "array",
        "items": {
          "type": "number"
        },
        "minItems": 2,
        "maxItems": 3
      },
      "minItems": 2
    },
    "linearRing": {
      "type": "array",
      "items": {
        "type": "array",
        "items": {
          "type": "number"
        },
        "minItems": 2,
        "maxItems": 3
      },
      "minItems": 4
    },
    "polygonCoordinates": {
      "type": "array",
      "items": {
        "type": "array",
        "items": {
          "type": "array",
          "items": {
            "type": "number"
          },
          "minItems": 2,
          "maxItems": 3
        },
        "minItems": 4
      },
      "minItems": 1
    },
    "multiPolygonCoordinates": {
      "type": "array",
      "items": {
        "type": "array",
        "items": {
          "type": "array",
          "items": {
            "type": "array",
            "items": {
              "type": "number"
            },
            "minItems": 2,
            "maxItems": 3
          },
          "minItems": 4
        },
        "minItems": 1
      },
      "minItems": 1
    },
    "bbox": {
      "type": "array",
      "items": {
        "type": "number"
      },
      "minItems": 4
    },
    "point": {
      "type": "object",
      "required": [
        "type",
        "coordinates"
      ],
      "properties": {
        "type": {
          "const": "Point"
        },
        "coordinates": {
          "$ref": "#/$defs/position"
        },
        "bbox": {
          "$ref": "#/$defs/bbox"
        }
      }
    },
    "multiPoint": {
      "type": "object",
      "required": [
        "type",
        "coordinates"
      ],
      "properties": {
        "type": {
          "const": "MultiPoint"
        },
        "coordinates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/position"
          }
        },
        "bbox": {
          "$ref": "#/$defs/bbox"
        }
      }
    },
    "lineString": {
      "type": "object",
      "required": [
        "type",
        "coordinates"
      ],
      "properties": {
        "type": {
          "const": "LineString"
        },
        "coordinates": {
          "$ref": "#/$defs/lineStringCoordinates"
        },
        "bbox": {
          "$ref": "#/$defs/bbox"
        }
      }
    },
    "multiLineString": {
      "type": "object",
      "required": [
        "type",
        "coordinates"
      ],
      "properties": {
        "type": {
          "const": "MultiLineString"
        },
        "coordinates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/lineStringCoordinates"
          }
        },
        "bbox": {
          "$ref": "#/$defs/bbox"
        }
      }
    },
    "polygon": {
      "type": "object",
      "required": [
        "type",
        "coordinates"
      ],
      "properties": {
        "type": {
          "const": "Polygon"
        },
        "coordinates": {
          "$ref": "#/$defs/polygonCoordinates"
        },
        "bbox": {
          "$ref": "#/$defs/bbox"
        }
      }
    },
    "multiPolygon": {
      "type": "object",
      "required": [
        "type",
        "coordinates"
      ],
      "properties": {
        "type": {
          "const": "MultiPolygon"
        },
        "coordinates": {
          "$ref": "#/$defs/multiPolygonCoordinates"
        },
        "bbox": {
          "$ref": "#/$defs/bbox"
        }
      }
    },
    "geometry": {
      "oneOf": [
        {
          "$ref": "#/$defs/point"
        },
        {
          "$ref": "#/$defs/multiPoint"
        },
        {
          "$ref": "#/$defs/lineString"
        },
        {
          "$ref": "#/$defs/multiLineString"
        },
        {
          "$ref": "#/$defs/polygon"
        },
        {
          "$ref": "#/$defs/multiPolygon"
        },
        {
          "$ref": "#/$defs/geometryCollection"
        }
      ]
    },
    "geometryCollection": {
      "type": "object",
      "required": [
        "type",
        "geometries"
      ],
      "properties": {
        "type": {
          "const": "GeometryCollection"
        },
        "geometries": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/geometry"
          }
        },
        "bbox": {
          "$ref": "#/$defs/bbox"
        }
      }
    },
    "feature": {
      "type": "object",
      "required": [
        "type",
        "geometry",
        "properties"
      ],
      "properties": {
        "type": {
          "const": "Feature"
        },
        "geometry": {
          "oneOf": [
            {
              "$ref": "#/$defs/geometry"
            },
            {
              "type": "null"
            }
          ]
        },
        "properties": {
          "oneOf": [
            {
              "type": "object"
            },
            {
              "type": "null"
            }
          ]
        },
        "bbox": {
          "$ref": "#/$defs/bbox"
        }
      }
    },
    "featureCollection": {
      "type": "object",
      "required": [
        "type",
        "features"
      ],
      "properties": {
        "type": {
          "const": "FeatureCollection"
        },
        "features": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/feature"
          }
        },
        "bbox": {
          "$ref": "#/$defs/bbox"
        }
      }
    }
  }
}
