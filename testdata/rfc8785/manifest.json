      "expectedCanonicalJSON": "canonical/property_sorting.expected.json",
      "expectedCanonicalUTF8Hex": "canonical/property_sorting.expected.hex",
      "expectedCanonicalJSONSHA256": "5e321556d22018a9656991a9e94f77ec175fa193e52a2429d312f8419ec8b08c"
    },
    {
      "name": "recursive_sorting",
      "source": "RFC 8785 Section 3.2.3",
